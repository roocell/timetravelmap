generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["timetravelmap"]
}

enum FindType {
  coin
  ring
  jewelry
  artifact
  other

  @@schema("timetravelmap")
  @@map("find_type")
}

enum MetalCode {
  C
  S
  G

  @@schema("timetravelmap")
  @@map("metal_code")
}

model Image {
  id             String      @id @default(uuid()) @db.Uuid
  ownerId        String?     @map("owner_id")
  storagePath    String      @unique @map("storage_path")
  originalUrl    String?     @map("original_url")
  mimeType       String?     @map("mime_type")
  width          Int?
  height         Int?
  byteSize       BigInt?     @map("byte_size")
  altText        String?     @map("alt_text")
  sourceName     String?     @map("source_name")
  checksumSha256 String?     @map("checksum_sha256")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  eventImages    EventImage[]
  findImages     FindImage[]
  prospectImages ProspectImage[]

  @@map("images")
  @@schema("timetravelmap")
  @@index([ownerId], map: "images_owner_id_idx")
}

model Event {
  id               String                @id @default(uuid()) @db.Uuid
  ownerId          String?               @map("owner_id")
  title            String
  eventDate        DateTime              @map("event_date") @db.Date
  durationMinutes  Int?                  @map("duration_minutes")
  deviceUsed       String?               @map("device_used")
  deviceMode       String?               @map("device_mode")
  description      String?
  fillColor        String?               @map("fill_color")
  outlineColor     String?               @map("outline_color")
  outlineWidth     Decimal?              @map("outline_width") @db.Decimal(6, 2)
  area             Unsupported("geometry(MultiPolygon, 4326)")
  sourceFile       String?               @map("source_file")
  sourcePlacemarkId String?              @map("source_placemark_id")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  eventImages      EventImage[]
  finds            Find[]

  @@index([ownerId], map: "events_owner_id_idx")
  @@map("events")
  @@schema("timetravelmap")
}

model EventImage {
  eventId   String @map("event_id") @db.Uuid
  imageId   String @map("image_id") @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")
  caption   String?
  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  image     Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([eventId, imageId])
  @@index([eventId, sortOrder, imageId], map: "event_images_sort_idx")
  @@map("event_images")
  @@schema("timetravelmap")
}

model Find {
  id               String                @id @default(uuid()) @db.Uuid
  ownerId          String?               @map("owner_id")
  eventId          String?               @map("event_id") @db.Uuid
  title            String
  findDate         DateTime              @map("find_date") @db.Date
  ageLabel         String?               @map("age_label")
  ageStartYear     Int?                  @map("age_start_year")
  ageEndYear       Int?                  @map("age_end_year")
  type             FindType
  metal            MetalCode?
  itemCount        Int?                  @map("item_count")
  description      String?
  latitude         Float
  longitude        Float
  sourceFile       String?               @map("source_file")
  sourcePlacemarkId String?              @map("source_placemark_id")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  event            Event?                @relation(fields: [eventId], references: [id], onDelete: SetNull)
  findImages       FindImage[]

  @@index([eventId], map: "finds_event_id_idx")
  @@index([ownerId], map: "finds_owner_id_idx")
  @@index([findDate(sort: Desc)], map: "finds_find_date_idx")
  @@index([latitude], map: "finds_latitude_idx")
  @@index([longitude], map: "finds_longitude_idx")
  @@index([type], map: "finds_type_idx")
  @@index([metal], map: "finds_metal_idx")
  @@map("finds")
  @@schema("timetravelmap")
}

model Prospect {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String?  @map("owner_id")
  title       String
  ageLabel    String?  @map("age_label")
  ageStartYear Int?    @map("age_start_year")
  ageEndYear  Int?     @map("age_end_year")
  description String?
  latitude    Float
  longitude   Float
  dateVisited DateTime? @map("date_visited") @db.Date
  sourceFile  String?  @map("source_file")
  sourcePlacemarkId String? @map("source_placemark_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  prospectImages ProspectImage[]

  @@index([ownerId], map: "prospects_owner_id_idx")
  @@index([dateVisited(sort: Desc)], map: "prospects_date_visited_idx")
  @@index([latitude], map: "prospects_latitude_idx")
  @@index([longitude], map: "prospects_longitude_idx")
  @@map("prospects")
  @@schema("timetravelmap")
}

model ProspectImage {
  prospectId String   @map("prospect_id") @db.Uuid
  imageId    String   @map("image_id") @db.Uuid
  sortOrder  Int      @default(0) @map("sort_order")
  caption    String?
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  image      Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([prospectId, imageId])
  @@index([prospectId, sortOrder, imageId], map: "prospect_images_sort_idx")
  @@map("prospect_images")
  @@schema("timetravelmap")
}

model FindImage {
  findId    String @map("find_id") @db.Uuid
  imageId   String @map("image_id") @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")
  caption   String?
  find      Find   @relation(fields: [findId], references: [id], onDelete: Cascade)
  image     Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([findId, imageId])
  @@index([findId, sortOrder, imageId], map: "find_images_sort_idx")
  @@map("find_images")
  @@schema("timetravelmap")
}
